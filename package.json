{
  "name": "anoncitizen",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Privacy-preserving zero-knowledge proof protocol for Aadhaar identity verification",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.0.0",
    "@types/qrcode": "^1.5.6",
    "eslint": "^9.0.0",
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "keccak",
      "secp256k1",
      "blake-hash",
      "sharp"
    ]
  }

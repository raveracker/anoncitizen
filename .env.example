# AnonCitizen Environment Variables
# Copy to .env and fill in your values

# ============================================================
# npm Publishing (GitHub Actions secret: NPM_TOKEN)
# ============================================================
NPM_TOKEN=

# ============================================================
# Contract Deployment (Polygon Amoy Testnet)
# ============================================================

AMOY_RPC_URL=https://rpc-amoy.polygon.technology
DEPLOYER_PRIVATE_KEY=

# ============================================================
# Circuit Artifacts (for SDK consumers)
# ============================================================

# URLs where circuit WASM and zkey are hosted
# VITE_ prefix exposes to browser; falls back to local files if not set
VITE_CIRCUIT_WASM_URL=https://<your-cdn.com>/circuits/aadhaar-verifier.wasm
VITE_CIRCUIT_ZKEY_URL=https://<your-cdn.com>/circuits/aadhaar-verifier.zkey
VITE_VERIFICATION_KEY_URL=https://<your-cdn.com>/circuits/verification_key.json

# ============================================================
# Development
# ============================================================

# Polygonscan API key for contract verification
POLYGONSCAN_API_KEY=

# ============================================================
# Cloudflare R2 (Circuit artifact storage + CDN)
# ============================================================

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://cdn.anoncitizen.xyz

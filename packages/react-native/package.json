{
  "name": "@anoncitizen/react-native",
  "version": "0.1.0",
  "description": "React Native (Expo) SDK for AnonCitizen ZK Aadhaar verification",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react-native --external expo",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "npx eslint src/",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "@anoncitizen/core": "workspace:*"
  },
  "peerDependencies": {
    "expo": ">=55.0.0",
    "expo-camera": ">=55.0.0",
    "react-native": ">=0.83.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "~19.2.10",
    "expo-camera": "~55.0.9",
    "expo-image-picker": "~55.0.12",
    "jsdom": "^28.1.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "tsup": "^8.3.0",
    "typescript": "~5.9.2",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anoncitizen/anoncitizen.git",
    "directory": "packages/react-native"
  },
  "homepage": "https://github.com/anoncitizen/anoncitizen/tree/main/packages/react-native",
  "bugs": {
    "url": "https://github.com/anoncitizen/anoncitizen/issues"
  },
  "keywords": [
    "aadhaar",
    "zero-knowledge",
    "react-native",
    "expo",
    "zk-proof",
    "privacy",
    "mobile"
  ]
}

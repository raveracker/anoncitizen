{
  "name": "@anoncitizen/core",
  "version": "1.2.0",
  "description": "Core TypeScript SDK for AnonCitizen ZK Aadhaar verification",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "artifacts"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "npx eslint src/",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "snarkjs": "^0.7.5",
    "pako": "^2.1.0",
    "@noble/hashes": "^1.7.0",
    "circomlibjs": "^0.1.7"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "@types/pako": "^2.0.3",
    "@types/snarkjs": "^0.7.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/raveracker/anoncitizen.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/raveracker/anoncitizen/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/raveracker/anoncitizen/issues"
  },
  "keywords": [
    "aadhaar",
    "zero-knowledge",
    "zk-proof",
    "groth16",
    "snarkjs",
    "privacy",
    "identity"
  ]
}
